{% extends "base.html.twig" %}

{% block title %}Inscription - Todo list PHP
{% endblock %}

{% block main %}
	<main class="d-flex form-main">
		<form action="/form/register" method="post">
			<div class="form-container">
				<h1>Inscription</h1>

				<div class="d-flex form-input">
					<label for="email" class="form-label">Adresse mail</label>
					<input type="email" name="email" id="email" required/>
				</div>

				<div class="d-flex form-input">
					<label for="username" class="form-label">Nom d'utilisateur</label>
					<input type="text" name="username" id="username" required/>
				</div>

				<div class="d-flex form-input">
					<label for="password" class="form-label">Mot de passe</label>
					<input type="password" name="password" id="password" required/>
				</div>

				<div class="d-flex submit-input">
					<input type="submit" name="register" class="d-flex" value="S'inscrire"/>
				</div>
			</div>
		</form>
	</main>
{% endblock %}
